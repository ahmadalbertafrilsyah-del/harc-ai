      // Mock data kombinasi dengan data real untuk UI R&D
      const data = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      
      // Jika kosong, kita berikan data simulasi agar tabel tidak kosong saat presentasi
      if (data.length === 0) {
