                    ) : log.status === "menunggu" ? (
                       <span className="text-[10px] font-bold text-amber-700 bg-amber-50 px-2 py-1 rounded border border-amber-200 flex items-center gap-1"><Clock size={12}/> Menunggu</span>
                    ) : null}
