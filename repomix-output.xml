              </div>
              <span className={`text-[9px] mt-0.5 font-bold transition-all ${isActive ? "text-purple-700" : "text-slate-400"} truncate px-1`}>
                {item.name}
              </span>
            </Link>
          );
        })}
      </nav>
    </div>
  );
}
